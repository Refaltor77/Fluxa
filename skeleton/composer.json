{
    "name": "fluxa/skeleton",
    "description": "Fluxa application skeleton — start a new API project in seconds",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.3",
        "fluxa/fluxa": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "serve": "php -S 127.0.0.1:8080 public/index.php",
        "post-create-project-cmd": [
            "@php vendor/bin/fluxa install:skeleton"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
