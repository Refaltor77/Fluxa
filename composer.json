{
    "name": "fluxa/fluxa",
    "description": "Ultra-minimalist, high-performance API micro-framework for PHP 8.3+",
    "type": "library",
    "license": "MIT",
    "keywords": ["framework", "api", "micro-framework", "rest", "json", "php8"],
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Fluxa\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Fluxa\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/fluxa"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
